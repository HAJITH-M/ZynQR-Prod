# API base URL (must include /api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Public app origin for /qr/:id links in the UI (optional)
VITE_PUBLIC_APP_URL=http://localhost:5173

# GitHub repo root for API Docs sidebar link (no trailing slash)
VITE_GITHUB_REPO_URL=https://github.com/your-org/zynqr
