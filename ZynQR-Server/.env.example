APP_ENV=development || production
APP_NAME=ZynQR
GIN_MODE=debug || release

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ats_db

REDIS_ADDR=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret

CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REDIRECT_URL=http://localhost:8000/api/v1/auth/google/callback
# Origin of the React app — the Google callback redirects here after success/failure
FRONTEND_URL=http://localhost:5173

SMTP_FROM=noreply@example.com
SMTP_PASSWORD=smtp_password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_URL=http://localhost:8000

# Inbox that receives POST /api/v1/contact submissions (defaults to SMTP_FROM)
CONTACT_INBOX_EMAIL=support@example.com

PORT=8000

# Origin for public /qr/<id> scan links (API host in local dev)
PUBLIC_SCAN_URL=http://localhost:8000

# Inactive dynamic QR redirect (full URL to your frontend page)
INACTIVE_QR_PAGE_URL=http://localhost:5178/link-inactive

# Deleted QR redirect (full URL when owner removed the code)
QR_NOT_FOUND_PAGE_URL=http://localhost:5178/qr-not-found

# IP geolocation API base (lookup URL is {base}/{ip}/json/)
IP_GEO_API_BASE_URL=https://ipapi.co